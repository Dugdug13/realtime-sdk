{
  "name": "react-kinetic-ui",
  "version": "0.0.4",
  "description": "A unified React Gesture library with sensor and contactless support, built on top of Framer Motion.",
  "scripts": {
    "rollup": "rollup -c",
    "build": "rollup -c --bundleConfigAsCjs"
  },
  "keywords": [
    "react",
    "component",
    "frontend",
    "Digipodium",
    "Digipod"
  ],
  "author": "Mohammad Mubassir",
  "license": "ISC",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/react": "^18.2.37",
    "rollup": "^4.5.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",

    "rollup-plugin-terser": "^7.0.2",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "18.2.0",
    "framer-motion": ">=10.0.0"
  },
  "main": "v1-dist/cjs/index.js",
  "module": "v1-dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./v1-dist/esm/index.js",
      "require": "./v1-dist/cjs/index.js"
    }
  },
  "files": [

    "v1-dist"
  ],
  
  "types": "v1-dist/index.d.ts",
  "type": "module",
  "dependencies": {
    "socket.io-client": "^4.8.1",
    "tslib": "^2.6.2"
  }
}
